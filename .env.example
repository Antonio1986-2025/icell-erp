# iCell ERP - Variáveis de Ambiente

# Banco de Dados (Railway fornece automaticamente via DATABASE_URL do PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/icell-erp?schema=public"

# NextAuth
AUTH_SECRET="gere-uma-chave-secreta-aqui-com-pelo-menos-32-caracteres"
AUTH_URL="https://seu-app.railway.app"

# Prisma
PRISMA_CLIENT_ENGINE_TYPE="dataproxy"
